{
	"name": "frakto-code-engine",
	"displayName": "Frakto Code Engine",
	"description": "%description%",
	"version": "1.0.0",
	"license": "MIT",
	"author": "Frakto Team",
	"repository": {
		"type": "git",
		"url": "https://github.com/fraktodev/frakto-code-engine.git"
	},
	"publisher": "frakto",
	"icon": "icon.png",
	"galleryBanner": {
		"color": "#2D3A78",
		"theme": "dark"
	},
	"categories": [
		"Formatters",
		"Linters",
		"Other"
	],
	"keywords": [
		"lint",
		"linter",
		"formatter",
		"code quality",
		"diagnostics",
		"custom linting",
		"universal linter",
		"external script",
		"style checker",
		"code analyzer",
		"multi-language",
		"frakto"
	],
	"engines": {
		"vscode": "^1.90.0"
	},
	"main": "./dist/extension.js",
	"activationEvents": [
		"onLanguage:javascript",
		"onLanguage:typescript",
		"onLanguage:javascriptreact",
		"onLanguage:typescriptreact",
		"onLanguage:html",
		"onLanguage:css",
		"onLanguage:scss",
		"onLanguage:less",
		"onLanguage:json",
		"onLanguage:jsonc",
		"onLanguage:markdown",
		"onLanguage:php",
		"onLanguage:xml",
		"onLanguage:yaml",
		"onLanguage:toml",
		"onLanguage:sql",
		"onLanguage:shellscript",
		"onLanguage:bash",
		"onLanguage:python",
		"onLanguage:ruby"
	],
	"contributes": {
		"commands": [
			{
				"command": "frakto.runDiagnostics",
				"title": "%command.title%",
				"category": "Frakto"
			}
		],
		"configuration": {
			"title": "%config.title%",
			"properties": {
				"frakto.execPath": {
					"type": "string",
					"markdownDescription": "%config.execPath.description%",
					"default": "",
					"scope": "language-overridable"
				},
				"frakto.enableFormat": {
					"type": "boolean",
					"default": true,
					"markdownDescription": "%config.enableFormat.description%",
					"scope": "language-overridable"
				},
				"frakto.enableDiagnostics": {
					"type": "boolean",
					"default": true,
					"markdownDescription": "%config.enableDiagnostics.description%",
					"scope": "language-overridable"
				},
				"frakto.linterStandard": {
					"type": [
						"string",
						"null"
					],
					"default": null,
					"markdownDescription": "%config.linterStandard.description%",
					"scope": "language-overridable"
				},
				"frakto.maxExecTime": {
					"type": "number",
					"default": 8000,
					"markdownDescription": "%config.maxExecTime.description%"
				},
				"frakto.debounceTime": {
					"type": "number",
					"default": 1000,
					"markdownDescription": "%config.debounceTime.description%"
				}
			}
		}
	},
	"scripts": {
		"build": "tsc -p .",
		"watch": "tsc -p . -w",
		"package": "vsce package"
	},
	"dependencies": {
		"vscode-nls": "^5.2.0"
	},
	"devDependencies": {
		"@types/node": "^24.2.1",
		"@types/vscode": "^1.85.0",
		"@vscode/vsce": "^3.6.0",
		"typescript": "^5.0.0"
	}
}
